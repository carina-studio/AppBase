<Project>
    
    <!-- Properties -->
    <PropertyGroup>

        <!-- Version -->
        <AssemblyVersion>2.4.0.506</AssemblyVersion>
        <PackageVersion>2.4.0.506-preview</PackageVersion>
        <Version>2.4.0.506</Version>

        <!-- Other information -->
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <Authors>Carina Studio</Authors>
        <Company>Carina Studio</Company>
        <Copyright>©2021-$([System.DateTime]::Now.Year) Carina Studio</Copyright>
        <Nullable>enable</Nullable>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageProjectUrl>https://carina-studio.github.io/AppBase/</PackageProjectUrl>
        
        <!-- Avalonia -->
        <AvaloniaVersion>12.0.0</AvaloniaVersion>

    </PropertyGroup>
    
</Project>